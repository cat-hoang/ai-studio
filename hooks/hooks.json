{
  "description": "Ratatosk Claude worker hooks",
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File \"${CLAUDE_PLUGIN_ROOT}\\hooks\\ensure-worker-report.ps1\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
