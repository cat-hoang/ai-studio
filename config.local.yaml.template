# Autotask per-machine configuration
# Copy this to config.local.yaml and fill in your values.
# config.local.yaml is gitignored.

worker_cli: "auto"                             # Worker launcher: auto, claude, or copilot
workspace_root: ""                             # Absolute path to your workspaces directory (e.g. C:\dev\autotask\workspaces)
artifacts_cache: ""                            # Absolute path to build artifact cache directory

# ---------------------------------------------------------------------------
# Issue source adapter — only GitHub Issues is supported
# ---------------------------------------------------------------------------
issue_source:
  adapter: "github-issues"

  # --- GitHub Issues ---
  github_issues:
    repo: your-org/your-repo
    labels: ready-for-dev
    assignee: me
    token_env: GITHUB_TOKEN

# ---------------------------------------------------------------------------
# Generic repo groups (studio mode — leave empty for legacy WTG mode)
# ---------------------------------------------------------------------------
# repo_groups:
#   backend:
#     - my-api
#   frontend:
#     - my-web-app

# build:
#   commands:
#     my-api: "dotnet build"
#   test_commands:
#     my-api: "dotnet test"

# ---------------------------------------------------------------------------
# Notifications
# ---------------------------------------------------------------------------
teams_chat_enabled: false                      # Enable direct Teams chat notifications
teams_chat_email: ""                           # Optional email hint for Teams cached auth
teams_chat_target_mode: "self"                 # self, person, chat, or conversation-id
teams_chat_target: ""                          # Required for person, chat, or conversation-id
teams_chat_command_polling_enabled: false
teams_chat_command_send_replies: true
teams_chat_command_prefix: "autotask:"
teams_chat_polling_interval_ms: 30000
smtp_server: "smtp.office365.com"
smtp_from: ""
smtp_to: ""
email_polling_interval_ms: 30000
email_poll_folder_path: "Inbox"
email_command_intake_enabled: false
email_command_send_replies: true
email_command_subject_prefix: "Autotask Command"
email_command_allowed_senders: ""

# ---------------------------------------------------------------------------
# Source root (optional — for reference-mode workspaces)
# ---------------------------------------------------------------------------
