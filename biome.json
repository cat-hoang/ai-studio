{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true
  },
  "organizeImports": {
    "enabled": false
  },
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "useOptionalChain": "off",
        "useLiteralKeys": "off",
        "noForEach": "off"
      },
      "style": {
        "useTemplate": "off",
        "useNodejsImportProtocol": "off",
        "useNumberNamespace": "off",
        "noNonNullAssertion": "off",
        "noArguments": "off"
      },
      "performance": {
        "noDelete": "off"
      }
    }
  }
}
