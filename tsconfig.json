{
  "compilerOptions": {
    // Bun-style: types are checked, never emitted (Bun runs .ts directly).
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "noEmit": true,

    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,

    // Bun provides fetch, process, Buffer, import.meta, __dirname, etc.
    "types": ["bun"]
  },
  "include": ["adapters", "tools", "tests"],
  "exclude": ["node_modules", "workspaces", "temp"]
}
